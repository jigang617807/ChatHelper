# Copy this file to .env, then fill in real secrets before running Docker Compose.

# Spring Boot app
APP_PORT=8080
ZHIPU_API_KEY=replace-with-your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas

# Agent-only DeepSeek chat model
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.4
DEEPSEEK_MAX_TOKENS=2048

# PostgreSQL + pgvector
POSTGRES_DB=rag_demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_PORT=5432

# Elasticsearch
ES_PORT=9200
ES_JAVA_OPTS=-Xms512m -Xmx512m

# RabbitMQ
RABBITMQ_DEFAULT_USER=chathelper
RABBITMQ_DEFAULT_PASS=change-this-rabbitmq-password
RABBITMQ_MANAGEMENT_PORT=15672

# RAG retrieval tuning
RAG_VECTOR_TOPK=20
RAG_BM25_TOPK=20
RAG_FINAL_TOPK=5
RAG_FUSION_STRATEGY=rrf
RAG_FUSION_RRF_K=60
RAG_FUSION_VECTOR_WEIGHT=0.6
RAG_FUSION_BM25_WEIGHT=0.4
RAG_RERANK_ENABLED=false

# Production-friendly defaults
SPRING_JPA_SHOW_SQL=false
SPRING_THYMELEAF_CACHE=true
